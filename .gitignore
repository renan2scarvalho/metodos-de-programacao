# ============================================================================
# .gitignore — metodos-de-programacao
# ============================================================================

# Compiled Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Virtual environments
.venv/
venv/
env/
envs/

# IDE
.idea/
.vscode/settings.json

# Environment
.env

# Logs
logs/

# Output e temporarios
outputs/
Output/
saida/
Saida/
data/
temp/

# Notebooks
.ipynb_checkpoints/

# Build e distribuicao
build/
dist/

# Coverage
.coverage
.coverage.*
htmlcov/

# Cache
.pytest_cache/
.ruff_cache/
.mypy_cache/

# UV/pip — lock gerenciado por uv.lock + pyproject.toml
requirements.txt

# Secrets
.secrets.toml

# Claude Code — permissoes locais (pode conter credenciais)
.claude/settings.json
.claude/settings.local.json

# Misc
**/*Zone.Identifier
~*.*
*.*~
